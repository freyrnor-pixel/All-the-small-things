{
  "expo": {
    "name": "UnFocus",
    "slug": "all-the-small-things",
    "owner": "freyrnor-pixel",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "unfocus",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/7ccb5393-f6b8-4a0f-8e45-8c86977d581c"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F4A261"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow UnFocus to use your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow UnFocus to access your photos to scan receipts."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.freyrnorpixel.unfocus"
    },
    "android": {
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.freyrnorpixel.unfocus"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7ccb5393-f6b8-4a0f-8e45-8c86977d581c"
      }
    }
  }
}
