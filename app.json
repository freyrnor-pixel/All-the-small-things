{
  "expo": {
    "name": "All the Small Things",
    "slug": "all-the-small-things",
    "owner": "freyrnor-pixel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "allthesmallthings",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F4A261"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow All the Small Things to use your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow All the Small Things to access your photos to scan receipts."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.freyrnorpixel.allthesmallthings"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6EC"
      },
      "package": "com.freyrnorpixel.allthesmallthings"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7ccb5393-f6b8-4a0f-8e45-8c86977d581c"
      }
    }
  }
}
